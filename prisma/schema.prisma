generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CollectionMediaType {
  HERO
  GALLERY
  VIDEO
  BACKGROUND
}

enum PromoPlacement {
  MERCHANDISE_HERO
  WELCOME_NARRATIVE
  COMMUNITY_CALLOUT
  FOOTER_CALLOUT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
  FULFILLED
}

model Collection {
  id              String                 @id @default(cuid())
  slug            String                 @unique
  name            String
  summary         String?
  heroCopy        String?
  heroImage       String?
  verified        Boolean                @default(false)
  mintingUrl      String?
  displayOrder    Int?                   @default(0)
  traits          CollectionTrait[]
  rarityTiers     CollectionRarityTier[]
  media           CollectionMedia[]
  nfts            Nft[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model CollectionTrait {
  id            String     @id @default(cuid())
  name          String
  values        String
  displayOrder  Int        @default(0)
  collectionId  String
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionRarityTier {
  id            String     @id @default(cuid())
  name          String
  percentage    String
  color         String?
  description   String?
  displayOrder  Int        @default(0)
  collectionId  String
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model CollectionMedia {
  id            String               @id @default(cuid())
  type          CollectionMediaType
  src           String
  alt           String?
  speed         Float?
  direction     String?
  opacity       Float?
  scale         Float?
  collectionId  String
  collection    Collection           @relation(fields: [collectionId], references: [id], onDelete: Cascade)
}

model Nft {
  id             String     @id @default(cuid())
  slug           String     @unique
  name           String
  subtitle       String?
  description    String?
  image          String
  gallery        String[]   @default([])
  rarity         String?
  rank           Int?
  score          Float?
  attributes     Json?
  supplyNumber   Int?
  externalUrl    String?
  isFeatured     Boolean    @default(false)
  displayOrder   Int        @default(0)
  collectionId   String
  collection     Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model MerchItem {
  id              String      @id @default(cuid())
  slug            String      @unique
  title           String
  description     String?
  baseUsdPrice    Decimal     @db.Decimal(10, 2)
  imageUrl        String?
  gallery         MerchMedia[]
  orders          Order[]
  isActive        Boolean     @default(true)
  deliveryRegions String[]    @default([])
  externalUrl     String?
  piPriceOverride Decimal?    @db.Decimal(18, 8)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model MerchMedia {
  id        String    @id @default(cuid())
  url       String
  alt       String?
  priority  Int       @default(0)
  merchId   String
  merchItem MerchItem @relation(fields: [merchId], references: [id], onDelete: Cascade)
}

model PromoBlock {
  id          String         @id @default(cuid())
  placement   PromoPlacement @unique
  heading     String
  subheading  String?
  body        String?
  ctaLabel    String?
  ctaUrl      String?
  mediaUrl    String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model CommunityLink {
  id           String   @id @default(cuid())
  name         String
  description  String?
  icon         String?
  url          String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FooterLink {
  id           String   @id @default(cuid())
  label        String
  href         String
  displayOrder Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PiPriceSnapshot {
  id            String   @id @default(cuid())
  piToUsdRate   Decimal  @db.Decimal(18, 8)
  source        String?
  fetchedAt     DateTime @default(now())
}

model PiUser {
  id                 String   @id @default(cuid())
  piUid              String   @unique
  username           String?
  walletAddress      String?
  lastAuthenticatedAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  orders             Order[]
}

model Order {
  id                String          @id @default(cuid())
  merchId           String
  merchItem         MerchItem       @relation(fields: [merchId], references: [id])
  quantity          Int             @default(1)
  unitUsdPrice      Decimal         @db.Decimal(10, 2)
  unitPiPrice       Decimal         @db.Decimal(18, 8)
  totalUsd          Decimal         @db.Decimal(12, 2)
  totalPi           Decimal         @db.Decimal(18, 8)
  status            OrderStatus     @default(PENDING)
  piPaymentId       String?
  customerName      String
  customerEmail     String
  customerPhone     String?
  shippingAddress   ShippingAddress?
  piUserId          String?
  piUser            PiUser?         @relation(fields: [piUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model ShippingAddress {
  id         String @id @default(cuid())
  orderId    String @unique
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  address1   String
  address2   String?
  city       String
  state      String?
  postalCode String
  country    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}